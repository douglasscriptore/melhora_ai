{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Melhora.AI",
  "version": "0.2.1",
  "identifier": "com.douglass.melhoraai",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Melhora.AI",
        "width": 480,
        "height": 600,
        "resizable": false,
        "center": false,
        "visible": false,
        "decorations": false,
        "transparent": true,
        "shadow": true,
        "alwaysOnTop": true,
        "skipTaskbar": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "infoPlist": "Info.plist"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDZENEVGQjJCQUMxNzVBNjMKUldSaldoZXNLL3RPYldyQlFuRkduNWlRR2pDMkdGQUFTYlovdmdHQ0xNZklkNW1xSDJRRDdhUEQK",
      "endpoints": [
        "https://github.com/douglasscriptore/melhora_ai/releases/latest/download/latest.json"
      ]
    },
    "sql": {
      "preloadConnections": ["sqlite:history.db"]
    }
  }
}
